# ============================================================
# PROD-SYS — Variables de entorno requeridas
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# Seguridad JWT — mínimo 32 caracteres, usar valor aleatorio en producción
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres

# Contraseña del administrador del sistema (solo para bootstrap inicial)
ADMIN_PASSWORD=cambia_esto_antes_de_usar

# Puerto del servidor HTTP
PORT=3000

# Entorno de ejecución: development | test | production
NODE_ENV=development

# Nombre del archivo de base de datos SQLite (dentro de backend/database/)
DB_SOURCE=mfcalidad.sqlite

# Nivel de logging Winston: error | warn | info | http | verbose | debug
LOG_LEVEL=info

# Acceso total en desarrollo. Cambiar a false para activar permisos por rol.
DISABLE_AUTH_CHECKS=true
