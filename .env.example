# ══════════════════════════════════════════════
# PROD-SYS — Variables de Entorno
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env real al repositorio.
# ══════════════════════════════════════════════

# ── Servidor ──────────────────────────────────
# Puerto en el que escucha el servidor HTTP.
PORT=3000

# Entorno de ejecución: development | test | production
NODE_ENV=development

# ── Seguridad ─────────────────────────────────
# Clave secreta para firmar tokens JWT.
# OBLIGATORIO. Mínimo 32 caracteres aleatorios.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Contraseña para el usuario administrador inicial.
# OBLIGATORIO. Solo se usa durante el bootstrap del sistema.
# Cámbiala inmediatamente después del primer inicio de sesión.
ADMIN_PASSWORD=

# ── Base de Datos ─────────────────────────────
# Nombre del archivo SQLite. Se crea automáticamente si no existe.
# En producción, usa una ruta absoluta fuera del directorio del proyecto.
# Ejemplo producción: /var/data/prodsys/mfcalidad.sqlite
DB_SOURCE=mfcalidad.sqlite

# ── Logging ───────────────────────────────────
# Nivel de log: error | warn | info | debug
# En producción usar: warn
LOG_LEVEL=info
